{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HelloTauri",
  "version": "0.1.0",
  "identifier": "com.hello.tauri",
  "build": {
    "beforeDevCommand": "pnpm run dev:web",
    "beforeBuildCommand": "pnpm run build:web",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hello Tauri",
        "width": 800,
        "height": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["hello-world"]
      }
    }
  }
}
